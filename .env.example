# ContextPacker MCP Server — environment variables
# Copy this file to .env and fill in your values.
# Note: MCP clients (Claude Desktop, Cursor) read env vars from their config JSON,
# not from .env files — see README.md for the correct setup.

# Required for hosted API (https://contextpacker.com)
CONTEXTPACKER_API_KEY=cp_live_your_key_here

# Optional: override API URL for self-hosted instances
# CONTEXTPACKER_API_URL=http://localhost:8000

# Optional: GitHub Personal Access Token for private repositories
# Needs at least `repo` scope
# GITHUB_PAT=ghp_your_token_here
